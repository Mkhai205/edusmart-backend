# --- Database Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=edusmart_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5432/edusmart_db

# --- MinIO Storage Configuration ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_SECURE=False
MINIO_BUCKET_NAME=edusmart-docs

# --- AI Configuration ---
GEMINI_API_KEY=your_gemini_api_key_here
# Embeddings
GOOGLE_EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=20
EMBEDDING_MAX_RETRIES=2
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
# Summarization
GOOGLE_SUMMARY_MODEL=gemini-2.0-flash
SUMMARY_TEMPERATURE=0.2
SUMMARY_MAX_TOKENS=2048
SUMMARY_REQUEST_TIMEOUT_SECONDS=90
SUMMARY_MAP_CHUNK_SIZE=12

# --- FastAPI Configuration ---
FASTAPI_HOST=localhost
FASTAPI_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# --- Google OAuth Configuration ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_LOGIN_SUCCESS_REDIRECT=http://localhost:3000/auth/callback/success
FRONTEND_LOGIN_FAILURE_REDIRECT=http://localhost:3000/auth/callback/error

# --- JWT Configuration ---
JWT_SECRET_KEY=replace_with_a_very_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Cookie Configuration ---
ACCESS_COOKIE_NAME=edusmart_access_token
REFRESH_COOKIE_NAME=edusmart_refresh_token
OAUTH_STATE_COOKIE_NAME=edusmart_oauth_state
COOKIE_DOMAIN=
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

